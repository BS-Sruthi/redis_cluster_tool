- name: Post Upgrade Verification
  hosts: redis-node-1
  gather_facts: no

  tasks:

    - name: Check cluster state
      shell: |
        redis-cli CLUSTER INFO | grep '^cluster_state:' | cut -d: -f2
      register: final_cluster
      changed_when: false

    - debug:
        msg:
          - "UPGRADE COMPLETE"
          - "Cluster State: {{ final_cluster.stdout }}"
