  hosts: redis-node-3
  become: yes
  gather_facts: no

  tasks:

    - name: Trigger failover on replica redis-node-4
      delegate_to: redis-node-4
      shell: redis-cli CLUSTER FAILOVER

    - name: Wait for failover
      pause:
        seconds: 15

    - name: Stop Redis on old master
      shell: pkill redis-server || true

