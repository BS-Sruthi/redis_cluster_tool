- name: Upgrade Replica redis-node-6
  hosts: redis-node-6
  become: yes
  gather_facts: no

  tasks:

    - name: Stop Redis
      shell: pkill redis-server || true

    - name: Download Redis 7.2.6
      get_url:
        url: https://download.redis.io/releases/redis-7.2.6.tar.gz
        dest: /tmp/redis-7.2.6.tar.gz

    - name: Extract Redis
      unarchive:
        src: /tmp/redis-7.2.6.tar.gz
        dest: /tmp
        remote_src: yes

    - name: Build Redis
      shell: |
        cd /tmp/redis-7.2.6
        make
        make install

    - name: Start Redis
      shell: redis-server /etc/redis.conf

    - pause:
        seconds: 20

    - name: Verify replica sync
      shell: |
        redis-cli INFO replication | grep '^master_link_status:' | cut -d: -f2
      register: replica_sync
      changed_when: false

    - fail:
        msg: "Replica redis-node-6 not synchronized"
      when: replica_sync.stdout != "up"

    - name: Verify cluster state
      shell: |
        redis-cli -h 10.10.0.11 CLUSTER INFO | grep '^cluster_state:' | cut -d: -f2
      register: cluster_check
      changed_when: false

    - fail:
        msg: "Cluster unhealthy after upgrading redis-node-6"
      when: cluster_check.stdout != "ok"

    - debug:
        msg: "[3/6] Upgraded replica redis-node-6 - cluster: ok"

- name: Upgrade Master redis-node-1
  hosts: redis-node-1
  become: yes
  gather_facts: no

  tasks:

    - name: Trigger failover on replica redis-node-5
      delegate_to: redis-node-5
      shell: redis-cli CLUSTER FAILOVER

    - name: Wait for failover
      pause:
        seconds: 15

    - name: Stop Redis on old master
      shell: pkill redis-server || true

    - name: Extract Redis 7.2.6
      unarchive:
        src: /tmp/redis-7.2.6.tar.gz
        dest: /tmp
        remote_src: yes

    - name: Build Redis
      shell: |
        cd /tmp/redis-7.2.6
        make
        make install

    - name: Start Redis
      shell: redis-server /etc/redis.conf

    - name: Wait for node
      pause:
        seconds: 20

    - name: Verify cluster state
      shell: |
        redis-cli -h 10.10.0.12 CLUSTER INFO | grep '^cluster_state:' | cut -d: -f2
      register: cluster_check
      changed_when: false

    - fail:
        msg: "Cluster unhealthy after upgrading redis-node-1"
      when: cluster_check.stdout != "ok"

    - debug:
        msg: "[4/6] Upgraded master redis-node-1 - cluster: ok"

